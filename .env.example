# Model routing
LOCAL_MODEL_ENABLED=true
LOCAL_MODEL_ENDPOINT=http://host.docker.internal:11434
LOCAL_MODEL_MODEL=qwen2.5-coder:7b
LOCAL_MODEL_FAST_MODEL=qwen2.5-coder:1.5b-base
LOCAL_MODEL_FAST_TASK_TYPES=format,docs,tiny-refactor,rename,simple-test
CLAUDE_MODEL=claude-sonnet-4
FORCE_CLAUDE=false
FORCE_LOCAL=false
MODEL_ROUTE_LOG=.ai/route-log.jsonl

# Optional feature toggles
CAVEMAN_ENABLED=1
CAVEMAN_INSTALL_SHA256=8ddef49c15f089c26affed3c31d97142c683e1d37a1499ae557281ca09c2712c
CAVEMAN_MODE=lite
BMAD_ENABLED=1

# ── Claude Plugin Tokens ──────────────────────────────────────────────────────
# github@claude-plugins-official — GitHub Personal Access Token
# Required scopes: repo, issues, pull_requests
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# semgrep@claude-plugins-official — Semgrep Cloud token (optional)
# Only needed for Semgrep Cloud features; local .semgrep.yml rules work without it
# Create at: https://semgrep.dev/orgs/-/settings/tokens
SEMGREP_APP_TOKEN=
