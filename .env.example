# FoundryVTT Docker Deployment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Preferred download method: timed URL from Foundry website (Node.js)
# 1) Go to https://foundryvtt.com/me/licenses
# 2) Set Operating System to Node.js
# 3) Click Timed URL and paste it below
FOUNDRY_RELEASE_URL=https://your-timed-url-here

# Optional fallback: Foundry website credentials
# Leave these blank when using FOUNDRY_RELEASE_URL
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=

# FoundryVTT Configuration
FOUNDRY_ADMIN_KEY=
FOUNDRY_VERSION=14.363
FOUNDRY_TELEMETRY=false

# Performance (both default to true; only set these to override)
# FOUNDRY_MINIFY_STATIC_FILES=true   # compress static assets (maps, tokens, audio)
# FOUNDRY_COMPRESS_WEBSOCKET=true    # compress websocket traffic

# Local compose setup note:
# Configure this file directly for startup; no deploy script is required.

# Port Configuration
FOUNDRY_PORT=30000
FOUNDRY_PROXY_PORT=

# Hostname Configuration
FOUNDRY_HOSTNAME=
FOUNDRY_LOCAL_HOSTNAME=

# Data Path
FOUNDRY_DATA_PATH=~/.local/share/FoundryVTT

# SSL/HTTPS Configuration (optional)
# FOUNDRY_SSL_CERT=
# FOUNDRY_SSL_KEY=
# FOUNDRY_PROTOCOL=https

# ngrok Configuration (for remote access via ngrok)
NGROK_ENABLED=false
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
NGROK_NGROK_PROTOCOL=http

# Backup Restore Configuration (rsync over SSH)
# Mirror full FoundryVTT user data from another laptop
BACKUP_REMOTE_USER=
BACKUP_REMOTE_IP=
BACKUP_REMOTE_HOST=
BACKUP_REMOTE_PATH=~/.local/share/FoundryVTT
# Local rsync destination; deploy-setup.sh sets FOUNDRY_BACKUPS_PATH to BACKUP_LOCAL_PATH/Backups
BACKUP_LOCAL_PATH=~/.local/share/FoundryVTT
BACKUP_SSH_KEY=~/.ssh/id_rsa
FOUNDRY_BACKUPS_PATH=~/.local/share/FoundryVTT/Backups

# GPU Support
GPU_ENABLED=false
# GPU_DEVICE_IDS=0  # Comma-separated list of GPU device IDs to expose

# Container Configuration
CONTAINER_CACHE=/data/container_cache
CONTAINER_CACHE_SIZE=
CONTAINER_VERBOSE=false
CONTAINER_UMASK=

# ── Template foundation: model routing (see docs/AI_ROUTING_POLICY.md) ────────
# Local-model offload is OFF by default for this repo; enable only if Ollama is
# installed and bound per docs/TEMPLATE_GUIDE.md. Everything routes to Claude
# while this is false.
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_ENDPOINT=http://host.docker.internal:11434
LOCAL_MODEL_MODEL=qwen2.5-coder:7b
LOCAL_MODEL_FAST_MODEL=qwen2.5-coder:1.5b-base
LOCAL_MODEL_FAST_TASK_TYPES=format,docs,tiny-refactor,rename,simple-test
CLAUDE_MODEL=claude-sonnet-4-6
FORCE_CLAUDE=false
FORCE_LOCAL=false
MODEL_ROUTE_LOG=.ai/route-log.jsonl

# Delegation lifecycle (scripts/delegate-local.sh + scripts/local-health.sh)
LOCAL_MODEL_TIMEOUT=120        # hard cap (s) per local generation before escalating
LOCAL_MODEL_MAX_OUTPUT=2048    # num_predict cap per local generation
LOCAL_MODEL_MIN_TPS=5          # tokens/sec floor; slower marks the model degraded
LOCAL_HEALTH_CACHE=.ai/local-health.json
LOCAL_HEALTH_TTL=300           # seconds a health probe stays valid
LOCAL_MODEL_PROBE_TIMEOUT=45   # max seconds for the health speed probe

# Optional template feature toggles
CAVEMAN_ENABLED=1
CAVEMAN_INSTALL_SHA256=8ddef49c15f089c26affed3c31d97142c683e1d37a1499ae557281ca09c2712c
CAVEMAN_MODE=lite
BMAD_ENABLED=1

# ── GitHub auth ───────────────────────────────────────────────────────────────
# Do NOT put a GitHub token here (or in any env var / repo file). Authenticate
# in the container terminal with browser OAuth instead:
#   gh auth login --hostname github.com --git-protocol https --web
# The token lands in gh's config (a named volume outside the workspace), git
# uses it via gh's credential helper, and nothing is readable from the repo.
