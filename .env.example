# FoundryVTT Docker Deployment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# FoundryVTT Credentials (Required for pre-installed release)
FOUNDRY_USERNAME=your_foundry_username
FOUNDRY_PASSWORD=your_foundry_password

# FoundryVTT Configuration
FOUNDRY_ADMIN_KEY=atropos
FOUNDRY_VERSION=14.363
FOUNDRY_TELEMETRY=true

# Optional: Use pre-signed URL instead of credentials (if available)
# FOUNDRY_RELEASE_URL=https://your-presigned-url-here

# Port Configuration
FOUNDRY_PORT=30000
FOUNDRY_PROXY_PORT=

# Hostname Configuration
FOUNDRY_HOSTNAME=
FOUNDRY_LOCAL_HOSTNAME=

# Data Path
FOUNDRY_DATA_PATH=./data

# SSL/HTTPS Configuration (optional)
# FOUNDRY_SSL_CERT=
# FOUNDRY_SSL_KEY=
# FOUNDRY_PROTOCOL=https

# ngrok Configuration (for remote access via ngrok)
NGROK_ENABLED=false
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
NGROK_REGION=eu  # Options: us, eu, ap, au, sa, jp, in
NGROK_NGROK_PROTOCOL=http

# File Sync Configuration (Syncthing - Bidirectional)
# Syncthing syncs only changed blocks, never rewrites unchanged files
SYNC_ENABLED=false
SYNC_METHOD=syncthing

# Syncthing Configuration
# Generate API key: docker compose exec syncthing curl -s http://localhost:8384/api/system/config | jq '.gui.apikey'
SYNCTHING_API_KEY=

# Optional: Syncthing remote device ID (for connecting secondary laptop)
# Find device ID: Open http://localhost:8384 and copy "This Device"
SYNCTHING_DEVICE_ID=

# GPU Support
GPU_ENABLED=false
# GPU_DEVICE_IDS=0  # Comma-separated list of GPU device IDs to expose

# Container Configuration
CONTAINER_CACHE=/data/container_cache
CONTAINER_CACHE_SIZE=
CONTAINER_VERBOSE=false
CONTAINER_UMASK=
