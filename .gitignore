# This file specifies intentionally untracked files that Git should ignore.
# Files already tracked by Git are not affected.
# See: https://git-scm.com/docs/gitignore

## DirEnv ##
.envrc

## Environment & Secrets (NEVER commit!) ##
.env
.env.*
!.env.example
.env.local
.env.*.local
secrets.*
*.p12
*.pfx

## Credentials & API Keys ##
cookiejar.json
license.json
*.key
*.pem
*.cert
secret.txt

## FoundryVTT ##
cookiejar.json
license.json

## Foundry MCP server (installed by scripts/setup-mcp.sh) ##
mcp-server/

## Javascript / Typescript ##
dist
node_modules
npm-debug.log*
build
coverage

## Python ##
__pycache__
.hypothesis
.mypy_cache
.pytest_cache
.python-version
*.egg-info
venv
.venv

## Claude / agent runtime state (template assets in .claude/ stay tracked) ##
.claude/mcp.json
.claude/settings.local.json
.claude/todos/
.claude/cache/
.claude/history/
.claude/statsig/
.claude/worktrees/
.ai/

## BMAD generated output (installed at container start; never commit) ##
_bmad/
_bmad-output/
.claude/skills/bmad-*

## Devcontainer / tooling runtime artifacts ##
.gitconfig
.cache/

## CI scan outputs (generated by semgrep.yml / container-scan.yml) ##
*.sarif

## OS / editor ##
.DS_Store
.vscode/settings.json

# Foundry content module build output
content/dist/
scripts/content/node_modules/
